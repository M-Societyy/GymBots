{
  "name": "gymbots",
  "version": "1.0.0",
  "description": "Sistema avanzado y modular de bots para Minecraft basado en Mineflayer",
  "main": "src/app.js",
  "type": "commonjs",
  "author": "c1q_ | M-Society | Gym Client Team",
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "gymbots": "src/cli.js"
  },
  "scripts": {
    "start": "node src/cli.js",
    "cli": "node src/cli.js",
    "build:win": "pkg . --targets node22-win-x64 --output dist/gymbots.exe"
  },
  "pkg": {
    "scripts": [
      "src/**/*.js"
    ],
    "assets": [
      "config/**/*.json",
      "src/web/public/**/*"
    ]
  },
  "dependencies": {
    "mineflayer": "^4.37.0",
    "mineflayer-pathfinder": "^2.4.5",
    "express": "^4.21.2",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@yao-pkg/pkg": "^6.0.1"
  }
}
